{
  "name": "solvit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clear": "pnpm -r exec rimraf node_modules dist .turbo lib && pnpm rimraf node_modules .turbo",
    "dev": "turbo run dev --parallel --no-cache",
    "serve": "turbo run serve --parallel --no-cache",
    "build": "turbo run build",
    "update-packages": "pnpm update -i -r --latest",
    "test": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@alphacifer/biome": "^0.0.10",
    "@alphacifer/tsconfig": "^0.0.15",
    "@biomejs/biome": "^2.4.12",
    "@types/globals": "workspace:^",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "^4.1.4",
    "lefthook": "^2.1.6",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@alphacifer/core-utils": "^0.0.9",
    "tslib": "^2.8.1"
  }
}
