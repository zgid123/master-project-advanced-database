NODE_ENV=development
PORT=3010
HOST=0.0.0.0
DATABASE_URL=postgres://jobsvc:jobsvc@localhost:6432/jobs
DIRECT_DB_URL=postgres://jobsvc:jobsvc@localhost:5432/jobs
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret
# Production auth: set JWT_PUBLIC_KEY or JWT_JWKS_URL to verify RS256 tokens.
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
JWT_JWKS_CACHE_TTL_MS=300000
JWT_JWKS_NEGATIVE_CACHE_TTL_MS=30000
LOG_LEVEL=info
PG_POOL_MAX_USES=7500
